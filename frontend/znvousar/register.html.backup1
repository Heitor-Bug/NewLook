<title>Criar Conta | NewLook</title>

<!-- Tailwind -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<!-- Configuração Tailwind do projeto -->
<script src="../js/tailwind.config.js"></script>

<!-- Estilos globais -->
<link rel="stylesheet" href="../css/styles.css">

<!-- Fontes -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet">

<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

</head>

<body class="bg-surface text-on-surface overflow-hidden">

<main class="flex h-screen w-full">

    <section class="login-hero hidden lg:flex lg:w-1/2 relative overflow-hidden">

<img
    src="../img/capacadastro.webp"
    alt="Moda"
    class="absolute inset-0 w-full h-full object-cover">

<div class="hero-overlay"></div>

<div class="relative z-10 flex flex-col justify-end p-margin-desktop h-full w-full">

    <div class="mb-12">

        <h1 class="font-display-lg text-white mb-6 leading-tight">
            Redefina o seu estilo<br>
            através da IA.
        </h1>

        <div class="flex flex-col gap-6">

            <div class="flex items-center gap-4 text-white">
                <div class="benefit-icon">
                    <span class="material-symbols-outlined">auto_awesome</span>
                </div>
                <span class="font-body-lg">Looks personalizados</span>
            </div>

            <div class="flex items-center gap-4 text-white">
                <div class="benefit-icon">
                    <span class="material-symbols-outlined">styler</span>
                </div>
                <span class="font-body-lg">Estilo baseado em IA</span>
            </div>

            <div class="flex items-center gap-4 text-white">
                <div class="benefit-icon">
                    <span class="material-symbols-outlined">bolt</span>
                </div>
                <span class="font-body-lg">Crie combinações em segundos</span>
            </div>

        </div>

    </div>

    <div class="text-white/60 font-label-md">
        NEWLOOK © 2026
    </div>

</div>
