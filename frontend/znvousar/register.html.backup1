</section>


    <!-- Lado direito -->
    <section
        class="w-full lg:w-1/2 h-full overflow-y-auto bg-surface flex items-center justify-center py-12 px-6 sm:px-12">

        <div class="w-full max-w-md flex flex-col gap-8">

            <!-- Logo -->
            <div>
                <h1 class="font-display-lg text-display-lg text-primary tracking-tight">
                    NewLook
                </h1>
            </div>

            <!-- Cabeçalho -->
            <div class="flex flex-col gap-1">

                <h2 class="font-headline-xl text-headline-xl text-on-surface">
                    Criar conta
                </h2>

                <p class="font-body-md text-on-surface-variant">
                    É rápido e fácil! Comece agora.
                </p>

            </div>

            <!-- Formulário -->
            <form id="register-form" class="flex flex-col gap-6">

                <div class="flex flex-col gap-4">

                    <!-- Nome -->
                    <div class="flex flex-col gap-1.5">

                        <label
                            for="name"
                            class="font-label-md text-secondary uppercase">

                            Nome completo

                        </label>

                        <input
                            id="name"
                            type="text"
                            placeholder="Ex: Maria Silva"
                            class="auth-input rounded-lg px-4 py-3 font-body-md text-on-surface bg-white">

                    </div>

                    <!-- Email -->
                    <div class="flex flex-col gap-1.5">

                        <label
                            for="email"
                            class="font-label-md text-secondary uppercase">

                            E-mail

                        </label>

                        <input
                            id="email"
                            type="email"
                            placeholder="seu@email.com"
                            class="input-understated rounded-lg px-4 py-3 font-body-md text-on-surface bg-white">

                    </div>

                    <!-- Senha -->
                    <div class="flex flex-col gap-1.5">

                        <label
                            for="password"
                            class="font-label-md text-secondary uppercase">

                            Senha

                        </label>

                        <input
                            id="password"
                            type="password"
                            placeholder="••••••••"
                            class="input-understated rounded-lg px-4 py-3 font-body-md text-on-surface bg-white">

                    </div>

                    <!-- Confirmar senha -->
                    <div class="flex flex-col gap-1.5">

                        <label
                            for="confirm_password"
                            class="font-label-md text-secondary uppercase">

                            Confirmar senha

                        </label>

                        <input
                            id="confirm_password"
                            type="password"
                            placeholder="••••••••"
                            class="input-understated rounded-lg px-4 py-3 font-body-md text-on-surface bg-white">

                    </div>

                </div>

                <!-- Termos -->
                <div class="flex items-start gap-3">

                    <input
                        id="terms"
                        type="checkbox"
                        class="mt-1 w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary">

                    <label
                        for="terms"
                        class="font-body-sm text-on-surface-variant">

                        Eu concordo com os

                        <a href="#" class="text-primary font-semibold hover:underline">
                            Termos de Uso
                        </a>

                        e a

                        <a href="#" class="text-primary font-semibold hover:underline">
                            Política de Privacidade
                        </a>.

                    </label>

                </div>

                <!-- Botão -->
                <button
                    id="register-btn"
                    type="submit"
                    class="auth-btn bg-primary text-on-primary py-4 rounded-lg font-headline-lg transition-all duration-300 hover:opacity-90">

                    Criar conta

                </button>

            </form>

            <!-- Divisor -->
            <div class="flex items-center gap-4">

                <div class="flex-1 h-px bg-outline-variant"></div>

                <span class="font-label-md text-secondary uppercase whitespace-nowrap">
                    Ou cadastre-se com
                </span>

                <div class="flex-1 h-px bg-outline-variant"></div>

            </div>

            <!-- Login Social
            <div class="grid grid-cols-3 gap-3">

                <button
                    class="flex items-center justify-center py-3 px-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors btn-interaction">

                    Google

                </button>

                <button
                    class="flex items-center justify-center py-3 px-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors btn-interaction">

                    Apple

                </button>

                <button
                    class="flex items-center justify-center py-3 px-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors btn-interaction">

                    Facebook

                </button>

            </div> -->

            <!-- Rodapé -->
            <div class="text-center">

                <p class="font-body-md text-on-surface-variant">

                    Já tem uma conta?

                    <a
                        href="login.html"
                        class="text-primary font-bold hover:underline">

                        Faça login

                    </a>

                </p>

            </div>

        </div>

    </section>

</main>

<script src="../js/register.js"></script>
```

</body>

</html>
